# =============================================
# БЛОК 1: НАСТРОЙКИ ЗАПУСКА ПРОГРАММЫ
# =============================================

# Команда, которая запускает программу. Если поле interpreter установлено, оно будет иметь приоритет, и эта команда запуска не будет ничего делать
run = "python3 main.py"

# Основной язык repl. Здесь могут быть и другие языки!
language = "python3"

# Точка входа в приложение
entrypoint = "main.py"

# Список glob-паттернов, указывающих, какие файлы и каталоги должны быть скрыты в рабочей области
hidden = ["venv", ".config", "**/__pycache__", "**/.mypy_cache", "**/*.pyc"]

# Модули, используемые в проекте
modules = ["python-3.10"]

# =============================================
# БЛОК 2: НАСТРОЙКИ NIX-ОКРУЖЕНИЯ
# =============================================

# Указывает, какой канал nix использовать при сборке окружения
[nix]
channel = "stable-22_11"    # Стабильный канал от ноября 2022 года
packages = ["gdb"]

# =============================================
# БЛОК 3: ПЕРЕМЕННЫЕ ОКРУЖЕНИЯ
# =============================================

[env]   # Пустой блок - переменные окружения не заданы

# =============================================
# БЛОК 4: НАСТРОЙКИ МОДУЛЬНОГО ТЕСТИРОВАНИЯ
# =============================================

# Включение модульных тестов. Поддерживается только для нескольких языков
[unitTest]
language = "python3"   # Язык для модульных тестов

# =============================================
# БЛОК 5: НАСТРОЙКИ ИМПОРТА ИЗ GITHUB
# =============================================

# Это файлы, которые необходимо сохранить, когда этот языковой шаблон используется в качестве базового для репозиториев Python, импортированных из GitHub
[gitHubImport]
requiredFiles = [".replit", "replit.nix", ".config", "venv"]

# =============================================
# БЛОК 6: НАСТРОЙКИ РАЗВЕРТЫВАНИЯ
# =============================================

[deployment]
run = ["sh", "-c", "python3 main.py"]   # Команда запуска через оболочку sh

# =============================================
# БЛОК 7: НАСТРОЙКИ ПРОБРОСА ПОРТОВ
# =============================================

# Перенаправление внутреннего порта 5000 на внешний порт 80 (HTTP)
[[ports]]
localPort = 5000    # Внутренний порт, который слушает приложение Flask
externalPort = 80   # Внешний порт для доступа пользователей

# =============================================
# БЛОК 8: НАСТРОЙКИ АГЕНТА
# =============================================

[agent]
expertMode = true
