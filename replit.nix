# =============================================
# БЛОК 1: ОПРЕДЕЛЕНИЕ СИСТЕМНЫХ ЗАВИСИМОСТЕЙ (DEPS)
# =============================================
{ pkgs }: {
  deps = [
    # =============================================
    # БЛОК 2: ПАКЕТ prybar-python310
    # =============================================
    # Обеспечивает интеграцию Python 3.10 с платформой Replit
    # Позволяет запускать Python-код в песочнице Replit
    pkgs.replitPackages.prybar-python310

    # =============================================
    # БЛОК 3: ПАКЕТ stderred
    # =============================================
    # Перехватывает вывод stderr и отображает его красным цветом
    # Улучшает читаемость сообщений об ошибках в терминале
    pkgs.replitPackages.stderred
  ];
}